---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE, CONTACT_EMAIL, SOCIAL_LINKS } from '../consts';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead
			title={`About · ${SITE_TITLE}`}
			description="Dave Logan, Systems Engineering leader at VAST Data. Field notes from the AI era."
		/>
	</head>
	<body>
		<Header />
		<main>
			<section class="page-header">
				<div class="mono section-label">// about</div>
				<h1>Dave Logan</h1>
				<p class="dek mono">
					Manager, Systems Engineering · VAST Data · Enterprise Acquisition · USA-wide
				</p>
			</section>

			<section class="bio prose">
				<p>
					I lead the Systems Engineering team for Enterprise Acquisition at
					<a href="https://vastdata.com" target="_blank" rel="noopener">VAST Data</a>,
					where we help enterprises build the data infrastructure behind modern AI. The
					best part of the job is coaching Systems Engineers through a moment when
					the ground is moving; AI Operating Systems, agentic workflows, and
					long-context inference are changing what "enterprise infrastructure" means,
					and the SEs who figure it out first will define the next decade of the field.
				</p>

				<p>
					Outside the day job, I build AI tools in public. Strategic account plans
					used to cost thousands and take weeks; I built one that costs about seven
					dollars and takes a few minutes, and my team now uses it in the field. I
					write about that work, and about the craft of doing enterprise work in the
					AI era, here at aiwithdave.com.
				</p>

				<p>
					Thirty years in tech, four continents, two boys (one teen, one tween), one
					wife who just wrapped her first movie. I show up best when the problem is
					technical, the stakes are real, and the path is not obvious.
				</p>
			</section>

			<section class="elsewhere">
				<div class="mono section-label">// elsewhere</div>
				<ul class="link-list">
					<li><span class="label mono">X</span><a href={SOCIAL_LINKS.twitter} target="_blank" rel="noopener">@aiwithdave</a></li>
					<li><span class="label mono">GitHub</span><a href={SOCIAL_LINKS.github} target="_blank" rel="noopener">davidglogan</a></li>
					<li><span class="label mono">LinkedIn</span><a href={SOCIAL_LINKS.linkedin} target="_blank" rel="noopener">davidglogan</a></li>
					<li><span class="label mono">Email</span><a href={`mailto:${CONTACT_EMAIL}`}>{CONTACT_EMAIL}</a></li>
					<li><span class="label mono">RSS</span><a href="/rss.xml">/rss.xml</a></li>
					<li><span class="label mono">Employer</span><a href="https://vastdata.com" target="_blank" rel="noopener">VAST Data</a></li>
					<li><span class="label mono">Family</span><a href="https://reneelogan.com" target="_blank" rel="noopener">Renee Logan, novelist / filmmaker</a></li>
				</ul>
			</section>

			<section class="colophon">
				<div class="mono section-label">// colophon</div>
				<p class="dim">
					This site is an Astro static site hosted on Cloudflare Pages. Long-form
					body is set in Atkinson Hyperlegible, display in system serif, chrome in
					system monospace. Dark theme only; the faint scanlines are intentional.
					Source lives at
					<a href="https://github.com/davidglogan/aiwithdave-site" target="_blank" rel="noopener">github.com/davidglogan/aiwithdave-site</a>.
					Written with the help of
					<a href="https://claude.com/claude-code" target="_blank" rel="noopener">Claude</a>,
					in a workflow I will eventually write about here.
				</p>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	.page-header { margin: 1em 0 2.5em; }
	.section-label { color: var(--matrix); margin-bottom: 1em; }
	.page-header h1 {
		font-family: var(--font-serif);
		font-size: clamp(2.5rem, 5vw, 3.75rem);
		letter-spacing: -0.02em;
		margin: 0 0 0.3em;
		border: none;
		padding: 0;
	}
	.dek {
		color: var(--fg-muted);
		letter-spacing: 0.03em;
		text-transform: none;
		font-size: 0.92rem;
	}
	.bio {
		font-size: 1.12rem;
		line-height: 1.75;
		margin: 0 0 3.5em;
	}
	.bio p { margin-bottom: 1.4em; }
	.elsewhere { margin-bottom: 3.5em; }
	.link-list {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.link-list li {
		display: grid;
		grid-template-columns: 140px 1fr;
		gap: 1em;
		padding: 0.7em 0;
		border-bottom: 1px solid var(--rule);
		font-size: 1.02rem;
	}
	.link-list li:first-child { border-top: 1px solid var(--rule); }
	.link-list .label { color: var(--fg-muted); }
	.colophon { margin-bottom: 2em; }
	.colophon p { font-size: 0.98rem; line-height: 1.65; max-width: 38em; }
	.colophon .dim { color: var(--fg-muted); }
	@media (max-width: 720px) {
		.link-list li { grid-template-columns: 100px 1fr; gap: 0.6em; font-size: 0.98rem; }
	}
</style>
