---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const posts = (await getCollection('posts'))
	.filter((post) => post.data.status === 'published')
	.sort((a, b) => b.data.created.valueOf() - a.data.created.valueOf());
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={`Posts · ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="page-header">
				<div class="mono section-label">// archive</div>
				<h1>Posts</h1>
				<p class="dek">
					Field notes on AI infrastructure, practitioner craft, and the work of
					shipping software you didn't type. Roughly one per Tuesday.
				</p>
			</section>

			{posts.length === 0 ? (
				<div class="empty-state">
					<div class="terminal">
						<div class="term-line"><span class="prompt">$</span> ls posts/</div>
						<div class="term-line dim">&nbsp;</div>
						<div class="term-line dim">0 published posts. series launches Wed 21 May 2026.</div>
						<div class="term-line">
							<span class="prompt">$</span> subscribe <a href="/rss.xml">--rss</a>
							<span class="cursor" aria-hidden="true"></span>
						</div>
					</div>
				</div>
			) : (
				<ul class="post-list">
					{posts.map((post) => (
						<li>
							<a href={`/posts/${post.id}/`}>
								<div class="post-date mono"><FormattedDate date={post.data.created} /></div>
								<div>
									<div class="post-title">{post.data.title}</div>
									{post.data.subtitle && <div class="post-dek">{post.data.subtitle}</div>}
								</div>
							</a>
						</li>
					))}
				</ul>
			)}
		</main>
		<Footer />
	</body>
</html>

<style>
	.page-header { margin: 1em 0 3em; }
	.section-label { color: var(--matrix); margin-bottom: 1em; }
	.page-header h1 {
		font-family: var(--font-serif);
		font-size: clamp(2.4rem, 5vw, 3.5rem);
		margin: 0 0 0.4em;
		border: none;
		padding: 0;
	}
	.dek {
		font-size: 1.15rem;
		color: var(--fg-muted);
		max-width: 38em;
	}
	.empty-state {
		background: var(--bg-elev);
		border: 1px solid var(--rule);
		border-left: 3px solid var(--matrix);
		border-radius: var(--radius);
		padding: 1.5em 1.75em;
	}
	.terminal {
		font-family: var(--font-mono);
		font-size: 0.95rem;
		line-height: 1.8;
	}
	.term-line .prompt { color: var(--matrix); margin-right: 0.5em; }
	.term-line.dim { color: var(--fg-muted); }
	.term-line a { color: var(--fg-strong); border-bottom-color: var(--matrix); }
	.post-list {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.post-list li { margin: 0; border-bottom: 1px solid var(--rule); }
	.post-list li:first-child { border-top: 1px solid var(--rule); }
	.post-list a {
		display: grid;
		grid-template-columns: 160px 1fr;
		gap: 1.5em;
		padding: 1.5em 0;
		border: none;
	}
	.post-list a:hover .post-title { color: var(--matrix); }
	.post-date { color: var(--fg-muted); padding-top: 0.15em; }
	.post-title {
		font-family: var(--font-serif);
		font-size: 1.4rem;
		color: var(--fg-strong);
		transition: color 150ms ease;
	}
	.post-dek {
		margin-top: 0.25em;
		color: var(--fg-muted);
		font-size: 1rem;
	}
	@media (max-width: 720px) {
		.post-list a { grid-template-columns: 1fr; gap: 0.25em; }
	}
</style>
