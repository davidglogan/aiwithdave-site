---
import { SITE_TITLE, SOCIAL_LINKS, CONTACT_EMAIL } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

<header>
	<nav>
		<a href="/" class="brand" aria-label={`${SITE_TITLE}, home`}>
			<span class="brand-prompt">~$</span>
			<span class="brand-name">aiwithdave</span>
		</a>

		<div class="internal-links">
			<HeaderLink href="/">Home</HeaderLink>
			<HeaderLink href="/posts">Posts</HeaderLink>
			<HeaderLink href="/about">About</HeaderLink>
		</div>

		<div class="social-links">
			<a href={SOCIAL_LINKS.twitter} target="_blank" rel="noopener" title="Follow @aiwithdave on X">
				<span class="sr-only">Follow @aiwithdave on X</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="22" height="22"
					><path
						fill="currentColor"
						d="M5.026 15c6.038 0 9.341-5.003 9.341-9.334 0-.14 0-.282-.006-.422A6.685 6.685 0 0 0 16 3.542a6.658 6.658 0 0 1-1.889.518 3.301 3.301 0 0 0 1.447-1.817 6.533 6.533 0 0 1-2.087.793A3.286 3.286 0 0 0 7.875 6.03a9.325 9.325 0 0 1-6.767-3.429 3.289 3.289 0 0 0 1.018 4.382A3.323 3.323 0 0 1 .64 6.575v.045a3.288 3.288 0 0 0 2.632 3.218 3.203 3.203 0 0 1-.865.115 3.23 3.23 0 0 1-.614-.057 3.283 3.283 0 0 0 3.067 2.277A6.588 6.588 0 0 1 .78 13.58a6.32 6.32 0 0 1-.78-.045A9.344 9.344 0 0 0 5.026 15z"
					></path></svg
				>
			</a>
			<a href={SOCIAL_LINKS.github} target="_blank" rel="noopener" title="Dave on GitHub">
				<span class="sr-only">Dave's GitHub profile</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="22" height="22"
					><path
						fill="currentColor"
						d="M8 0C3.58 0 0 3.58 0 8c0 3.54 2.29 6.53 5.47 7.59.4.07.55-.17.55-.38 0-.19-.01-.82-.01-1.49-2.01.37-2.53-.49-2.69-.94-.09-.23-.48-.94-.82-1.13-.28-.15-.68-.52-.01-.53.63-.01 1.08.58 1.23.82.72 1.21 1.87.87 2.33.66.07-.52.28-.87.51-1.07-1.78-.2-3.64-.89-3.64-3.95 0-.87.31-1.59.82-2.15-.08-.2-.36-1.02.08-2.12 0 0 .67-.21 2.2.82.64-.18 1.32-.27 2-.27.68 0 1.36.09 2 .27 1.53-1.04 2.2-.82 2.2-.82.44 1.1.16 1.92.08 2.12.51.56.82 1.27.82 2.15 0 3.07-1.87 3.75-3.65 3.95.29.25.54.73.54 1.48 0 1.07-.01 1.93-.01 2.2 0 .21.15.46.55.38A8.012 8.012 0 0 0 16 8c0-4.42-3.58-8-8-8z"
					></path></svg
				>
			</a>
			<a href={SOCIAL_LINKS.linkedin} target="_blank" rel="noopener" title="Dave on LinkedIn">
				<span class="sr-only">Dave's LinkedIn profile</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="22" height="22"
					><path
						fill="currentColor"
						d="M13.632 13.635h-2.37V9.922c0-.886-.018-2.025-1.234-2.025-1.235 0-1.424.964-1.424 1.96v3.778h-2.37V6h2.275v1.04h.032c.317-.6 1.091-1.233 2.246-1.233 2.401 0 2.845 1.58 2.845 3.637v4.191zM3.558 4.955a1.374 1.374 0 1 1 0-2.748 1.374 1.374 0 0 1 0 2.748zm1.187 8.68h-2.37V6h2.37v7.635zM14.816 0H1.18C.528 0 0 .516 0 1.153v13.694C0 15.484.528 16 1.18 16h13.635c.652 0 1.185-.516 1.185-1.153V1.153C16 .516 15.467 0 14.815 0h.001z"
					></path></svg
				>
			</a>
			<a href="/rss.xml" title="RSS feed" aria-label="RSS feed">
				<span class="sr-only">RSS feed</span>
				<svg viewBox="0 0 16 16" aria-hidden="true" width="22" height="22"
					><path
						fill="currentColor"
						d="M3.5 12.5a1.5 1.5 0 1 0 0 3 1.5 1.5 0 0 0 0-3zM0 8.5a.5.5 0 0 1 .5-.5 7 7 0 0 1 7 7 .5.5 0 1 1-1 0 6 6 0 0 0-6-6 .5.5 0 0 1-.5-.5zm0-4a.5.5 0 0 1 .5-.5 11 11 0 0 1 11 11 .5.5 0 1 1-1 0 10 10 0 0 0-10-10 .5.5 0 0 1-.5-.5z"
					></path></svg
				>
			</a>
		</div>
	</nav>
</header>

<style>
	header {
		margin: 0;
		padding: 1em 1.5em;
		background: var(--bg);
		border-bottom: 1px solid var(--rule);
		position: relative;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
		max-width: var(--wide-width);
		margin: 0 auto;
		gap: 1.5em;
		flex-wrap: wrap;
	}
	.brand {
		font-family: var(--font-mono);
		font-size: 1.15rem;
		font-weight: 700;
		color: var(--fg-strong);
		text-decoration: none;
		border: none;
		display: flex;
		align-items: baseline;
		gap: 0.5em;
		letter-spacing: 0.01em;
	}
	.brand:hover, .brand:focus-visible {
		color: var(--matrix);
	}
	.brand-prompt {
		color: var(--matrix);
	}
	.internal-links {
		display: flex;
		gap: 0.25em;
		flex: 1;
		justify-content: center;
	}
	.internal-links :global(a) {
		font-family: var(--font-mono);
		font-size: 0.85rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		padding: 0.5em 0.9em;
		color: var(--fg-muted);
		border-bottom: 2px solid transparent;
		text-decoration: none;
	}
	.internal-links :global(a:hover),
	.internal-links :global(a:focus-visible) {
		color: var(--matrix);
		border-bottom-color: var(--matrix);
	}
	.internal-links :global(a.active) {
		color: var(--fg-strong);
		border-bottom-color: var(--matrix);
	}
	.social-links {
		display: flex;
		gap: 0.9em;
		align-items: center;
	}
	.social-links a {
		color: var(--fg-muted);
		border: none;
		display: flex;
		align-items: center;
	}
	.social-links a:hover, .social-links a:focus-visible {
		color: var(--matrix);
	}
	@media (max-width: 720px) {
		header { padding: 0.75em 1em; }
		nav { gap: 0.5em; }
		.social-links { display: none; }
		.internal-links { flex: auto; justify-content: flex-end; }
		.internal-links :global(a) { padding: 0.5em 0.6em; }
	}
</style>
