---
import { Image } from 'astro:assets';
import type { ImageMetadata } from 'astro';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

interface Props {
	title: string;
	subtitle?: string;
	status?: 'idea' | 'draft' | 'ready' | 'published';
	created: Date;
	updated?: Date;
	heroImage?: ImageMetadata;
	pillar?: string;
}

const { title, subtitle, status, created, updated, heroImage, pillar } = Astro.props;
const description = subtitle ?? title;
const isDraft = status !== 'published';
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={title} description={description} />
		{isDraft && <meta name="robots" content="noindex, nofollow" />}
	</head>

	<body>
		<Header />
		<main>
			<article>
				<header class="post-header">
					<div class="meta mono">
						{isDraft && <span class="chip">draft</span>}
						{pillar && <span class="pillar-tag">// {pillar}</span>}
						<time datetime={created.toISOString()}>
							<FormattedDate date={created} />
						</time>
						{updated && (
							<span class="updated">
								· updated <FormattedDate date={updated} />
							</span>
						)}
					</div>
					<h1 class="post-title">{title}</h1>
					{subtitle && <p class="post-subtitle">{subtitle}</p>}
				</header>

				{heroImage && (
					<div class="hero-image">
						<Image width={1200} height={630} src={heroImage} alt="" />
					</div>
				)}

				<div class="prose">
					<slot />
				</div>

				<footer class="post-footer">
					<div class="mono">// end of transmission</div>
					<p>
						If this was useful, you can follow along on
						<a href="https://x.com/aiwithdave" target="_blank" rel="noopener">X</a>,
						<a href="/rss.xml">RSS</a>, or
						<a href="/posts/">read the rest of the series</a>.
					</p>
				</footer>
			</article>
		</main>
		<Footer />
	</body>
</html>

<style>
	main {
		width: min(var(--content-width), calc(100% - 2em));
	}
	.post-header {
		margin: 1em 0 2.5em;
		padding-bottom: 1.5em;
		border-bottom: 1px solid var(--rule);
	}
	.meta {
		display: flex;
		flex-wrap: wrap;
		gap: 0.8em;
		align-items: center;
		color: var(--fg-muted);
		margin-bottom: 1.2em;
	}
	.pillar-tag { color: var(--matrix); }
	.meta .updated { color: var(--fg-faint); }
	.post-title {
		font-family: var(--font-serif);
		font-size: clamp(2rem, 4.5vw, 3.2rem);
		line-height: 1.1;
		letter-spacing: -0.02em;
		color: var(--fg-strong);
		margin: 0 0 0.5em;
		border: none;
		padding: 0;
	}
	.post-subtitle {
		font-family: var(--font-serif);
		font-style: italic;
		font-size: 1.25rem;
		color: var(--fg-muted);
		line-height: 1.45;
		margin: 0;
	}
	.hero-image {
		margin: 0 0 2.5em;
	}
	.hero-image img {
		display: block;
		width: 100%;
		height: auto;
		border-radius: var(--radius);
		border: 1px solid var(--rule);
	}
	.prose {
		font-size: 1.08rem;
		line-height: 1.75;
	}
	.prose :global(h2) {
		margin-top: 2.5em;
		border-bottom: 1px solid var(--rule);
		padding-bottom: 0.3em;
	}
	.prose :global(h3) {
		margin-top: 2em;
	}
	.prose :global(a) {
		color: var(--accent-hi);
	}
	.prose :global(a:hover) {
		color: var(--matrix);
	}
	.prose :global(table) {
		font-size: 0.95em;
	}
	.post-footer {
		margin-top: 4em;
		padding-top: 1.5em;
		border-top: 1px solid var(--rule);
		color: var(--fg-muted);
	}
	.post-footer .mono {
		color: var(--matrix);
		margin-bottom: 0.6em;
	}
	.post-footer p {
		margin: 0;
		font-size: 0.95rem;
	}

	@media (max-width: 720px) {
		.post-subtitle { font-size: 1.1rem; }
	}
</style>
