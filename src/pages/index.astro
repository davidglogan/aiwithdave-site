---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import FormattedDate from '../components/FormattedDate.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('posts'))
	.filter((post) => post.data.status === 'published')
	.sort((a, b) => b.data.created.valueOf() - a.data.created.valueOf())
	.slice(0, 6);
---

<!doctype html>
<html lang="en">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<section class="hero">
				<div class="hero-meta mono">&gt; boot sequence complete</div>
				<h1 class="hero-title">
					Building AI in<br />the real world.<span class="cursor" aria-hidden="true"></span>
				</h1>
				<p class="hero-dek">
					Dave Logan, Systems Engineering leader at VAST Data. Field notes
					from the AI era: enterprise infrastructure, practitioner craft,
					and the code I write with Claude after hours.
				</p>
				<div class="hero-cta">
					<a class="btn-primary" href="/posts/">Read the writing</a>
					<a class="btn-ghost" href="/about/">More about Dave</a>
				</div>
			</section>

			<section class="pillars">
				<div class="mono section-label">// what this blog is about</div>
				<div class="pillar-grid">
					<article class="pillar">
						<div class="pillar-num mono">01</div>
						<h3>AI infrastructure</h3>
						<p>GPUs, Kubernetes, storage, inference pipelines. What actually moves when enterprises build the layer under their AI.</p>
					</article>
					<article class="pillar">
						<div class="pillar-num mono">02</div>
						<h3>Practitioner craft</h3>
						<p>Vibe coding with Claude. What works, what doesn't, the traps and the unlocks when you ship code you didn't type.</p>
					</article>
					<article class="pillar">
						<div class="pillar-num mono">03</div>
						<h3>Enterprise data</h3>
						<p>Account planning, competitive intelligence, the work of selling infrastructure to Fortune 500s who already have feelings.</p>
					</article>
					<article class="pillar">
						<div class="pillar-num mono">04</div>
						<h3>The homelab</h3>
						<p>iGPUs, local inference, framework bake-offs, the hardware I test on a weeknight so I can speak to customers on Monday.</p>
					</article>
				</div>
			</section>

			<section class="latest">
				<div class="mono section-label">// latest posts</div>

				{posts.length === 0 ? (
					<div class="empty-state">
						<div class="terminal">
							<div class="term-line"><span class="prompt">$</span> ls posts/</div>
							<div class="term-line dim">&nbsp;</div>
							<div class="term-line dim">no published posts yet. series launches Wed 21 May 2026.</div>
							<div class="term-line dim">first post: <em>The $7 McKinsey Report — How I Used AI to Turn Enterprise Account Planning on Its Head</em>.</div>
							<div class="term-line">
								<span class="prompt">$</span> subscribe <a href="/rss.xml">--rss</a>
								<span class="prompt"> | </span> follow <a href="https://x.com/aiwithdave" target="_blank" rel="noopener">@aiwithdave</a>
								<span class="cursor" aria-hidden="true"></span>
							</div>
						</div>
					</div>
				) : (
					<ul class="post-list">
						{posts.map((post) => (
							<li>
								<a href={`/posts/${post.id}/`}>
									<div class="post-date mono"><FormattedDate date={post.data.created} /></div>
									<div class="post-title">{post.data.title}</div>
									{post.data.subtitle && <div class="post-dek">{post.data.subtitle}</div>}
								</a>
							</li>
						))}
					</ul>
				)}
			</section>

			<section class="signoff">
				<div class="mono section-label">// why a blog</div>
				<p class="signoff-text">
					Because the best way I know to understand something is to ship it,
					and the best way to understand shipping is to write about it in
					public. New posts arrive on Tuesday mornings. They take about
					thirty minutes to read and a few weeks to live with.
				</p>
				<p class="signoff-text dim">
					<em>— Dave</em>
				</p>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
	/* --- Hero --- */
	.hero { margin: 1.5em 0 4.5em; }
	.hero-meta {
		color: var(--matrix);
		margin-bottom: 1.2em;
	}
	.hero-title {
		font-family: var(--font-serif);
		font-size: clamp(2.4rem, 5vw, 3.75rem);
		line-height: 1.05;
		margin: 0 0 0.8em;
		color: var(--fg-strong);
		letter-spacing: -0.025em;
	}
	.hero-title .cursor { transform: translateY(0.05em); }
	.hero-dek {
		font-size: 1.2rem;
		color: var(--fg-muted);
		max-width: 38em;
		margin: 0 0 1.8em;
		line-height: 1.55;
	}
	.hero-cta { display: flex; gap: 0.9em; flex-wrap: wrap; }
	.btn-primary, .btn-ghost {
		display: inline-block;
		padding: 0.7em 1.4em;
		font-family: var(--font-mono);
		font-size: 0.88rem;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		border-radius: 4px;
		text-decoration: none;
		border: 1px solid var(--matrix);
	}
	.btn-primary {
		background: var(--matrix);
		color: var(--bg);
	}
	.btn-primary:hover, .btn-primary:focus-visible {
		background: transparent;
		color: var(--matrix);
	}
	.btn-ghost {
		background: transparent;
		color: var(--fg);
		border-color: var(--rule);
	}
	.btn-ghost:hover, .btn-ghost:focus-visible {
		color: var(--matrix);
		border-color: var(--matrix);
	}

	/* --- Section label --- */
	.section-label {
		color: var(--matrix);
		margin-bottom: 1.2em;
	}

	/* --- Pillars --- */
	.pillars { margin-bottom: 4em; }
	.pillar-grid {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 1.5em;
	}
	.pillar {
		padding: 1.4em 1.5em;
		background: var(--bg-elev);
		border: 1px solid var(--rule);
		border-radius: var(--radius);
		position: relative;
		transition: border-color 180ms ease, transform 180ms ease;
	}
	.pillar:hover {
		border-color: var(--matrix);
		transform: translateY(-2px);
	}
	.pillar-num {
		color: var(--matrix);
		margin-bottom: 0.6em;
	}
	.pillar h3 {
		font-family: var(--font-serif);
		font-size: 1.35rem;
		margin: 0 0 0.4em;
		color: var(--fg-strong);
	}
	.pillar p {
		margin: 0;
		font-size: 0.97rem;
		color: var(--fg-muted);
		line-height: 1.55;
	}

	/* --- Latest posts --- */
	.latest { margin-bottom: 4em; }
	.empty-state {
		background: var(--bg-elev);
		border: 1px solid var(--rule);
		border-left: 3px solid var(--matrix);
		border-radius: var(--radius);
		padding: 1.5em 1.75em;
	}
	.terminal {
		font-family: var(--font-mono);
		font-size: 0.95rem;
		line-height: 1.8;
		color: var(--fg);
	}
	.term-line .prompt {
		color: var(--matrix);
		margin-right: 0.5em;
	}
	.term-line.dim { color: var(--fg-muted); }
	.term-line a { color: var(--fg-strong); border-bottom-color: var(--matrix); }

	.post-list {
		list-style: none;
		padding: 0;
		margin: 0;
	}
	.post-list li { margin: 0; border-bottom: 1px solid var(--rule); }
	.post-list li:first-child { border-top: 1px solid var(--rule); }
	.post-list a {
		display: grid;
		grid-template-columns: 160px 1fr;
		gap: 1.5em;
		padding: 1.2em 0;
		border: none;
	}
	.post-list a:hover .post-title { color: var(--matrix); }
	.post-date { color: var(--fg-muted); padding-top: 0.15em; }
	.post-title {
		font-family: var(--font-serif);
		font-size: 1.3rem;
		color: var(--fg-strong);
		transition: color 150ms ease;
	}
	.post-dek {
		margin-top: 0.2em;
		color: var(--fg-muted);
		font-size: 0.95rem;
	}

	/* --- Signoff --- */
	.signoff { margin-bottom: 2em; }
	.signoff-text {
		font-family: var(--font-serif);
		font-style: italic;
		font-size: 1.15rem;
		line-height: 1.6;
		color: var(--fg);
		max-width: 38em;
	}
	.signoff-text.dim { color: var(--fg-muted); }

	@media (max-width: 720px) {
		.pillar-grid { grid-template-columns: 1fr; }
		.post-list a { grid-template-columns: 1fr; gap: 0.3em; }
		.hero-cta { flex-direction: column; align-items: flex-start; }
		.btn-primary, .btn-ghost { width: 100%; text-align: center; }
	}
</style>
