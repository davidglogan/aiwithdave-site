---
import { AUTHOR_NAME, SOCIAL_LINKS, CONTACT_EMAIL } from '../consts';
const today = new Date();
---

<footer>
	<div class="footer-inner">
		<div class="top">
			<div class="colophon">
				<div class="mono">// colophon</div>
				<p>
					Built in Astro on Cloudflare Pages. Atkinson Hyperlegible for body,
					system serif for display, system mono for chrome. Composed in
					<a href="https://neovim.io" target="_blank" rel="noopener">Neovim</a>
					and <a href="https://obsidian.md" target="_blank" rel="noopener">Obsidian</a>,
					drafted alongside
					<a href="https://claude.com/claude-code" target="_blank" rel="noopener">Claude</a>.
				</p>
			</div>
			<div class="follow">
				<div class="mono">// follow</div>
				<div class="social-links">
					<a href={SOCIAL_LINKS.twitter} target="_blank" rel="noopener">X · @aiwithdave</a>
					<a href={SOCIAL_LINKS.github} target="_blank" rel="noopener">GitHub · davidglogan</a>
					<a href={SOCIAL_LINKS.linkedin} target="_blank" rel="noopener">LinkedIn · davidglogan</a>
					<a href={`mailto:${CONTACT_EMAIL}`}>{CONTACT_EMAIL}</a>
					<a href="/rss.xml">RSS feed</a>
				</div>
			</div>
		</div>

		<div class="bottom">
			<div class="legal">
				&copy; {today.getFullYear()} {AUTHOR_NAME}. Raleigh, NC.
			</div>
			<div class="sdg" title="Soli Deo Gloria — to God alone the glory; a signoff used by Bach and the Reformers">
				S · D · G
			</div>
		</div>
	</div>
</footer>

<style>
	footer {
		margin-top: 4em;
		padding: 3em 1.5em 2em;
		background: var(--bg-inset);
		border-top: 1px solid var(--rule);
		color: var(--fg-muted);
	}
	.footer-inner {
		max-width: var(--wide-width);
		margin: 0 auto;
	}
	.top {
		display: grid;
		grid-template-columns: 1fr 1fr;
		gap: 3em;
		margin-bottom: 2.5em;
	}
	.colophon p {
		margin: 0;
		font-size: 0.95rem;
		line-height: 1.6;
	}
	.mono {
		font-family: var(--font-mono);
		font-size: 0.75rem;
		text-transform: uppercase;
		letter-spacing: 0.12em;
		color: var(--matrix);
		margin-bottom: 0.8em;
	}
	.social-links {
		display: flex;
		flex-direction: column;
		gap: 0.45em;
	}
	.social-links a {
		color: var(--fg);
		font-size: 0.95rem;
		border: none;
	}
	.social-links a:hover, .social-links a:focus-visible {
		color: var(--matrix);
	}
	.bottom {
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding-top: 1.5em;
		border-top: 1px solid var(--rule);
		font-family: var(--font-mono);
		font-size: 0.78rem;
		color: var(--fg-faint);
		letter-spacing: 0.05em;
	}
	.sdg {
		letter-spacing: 0.35em;
		color: var(--matrix);
		cursor: help;
		text-transform: none;
	}
	@media (max-width: 720px) {
		.top { grid-template-columns: 1fr; gap: 2em; }
		.bottom { flex-direction: column; align-items: flex-start; gap: 0.6em; }
	}
</style>
